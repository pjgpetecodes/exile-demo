{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Astronaut Game",
      "type": "pwa-msedge",
      "request": "launch",
      "url": "http://localhost:3000",
      "runtimeExecutable": "C:\\Program Files (x86)\\Microsoft\\Edge\\Application\\msedge.exe",
      "userDataDir": "${workspaceFolder}\\.vscode\\msedge-debug-profile",
      "webRoot": "${workspaceFolder}\\astronaut-game",
      "sourceMaps": true,
      "preLaunchTask": "dev astronaut-game",
      "postDebugTask": "stop astronaut-game dev"
    }
  ]
}
