{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build astronaut-game",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}\\astronaut-game"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$tsc"
    },
    {
      "label": "dev astronaut-game",
      "type": "shell",
      "command": "npm run dev",
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}\\astronaut-game"
      },
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^DO_NOT_MATCH_TASK_OUTPUT$",
          "message": 0
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "\\[Browsersync\\] Access URLs:"
        }
      }
    },
    {
      "label": "stop astronaut-game dev",
      "type": "process",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\.vscode\\stop-astronaut-game-dev.ps1"
      ],
      "problemMatcher": []
    }
  ]
}
